# ─── Supabase Configuration ───────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# Service Role key — used for backend-only operations (skill profile updates)
# Found in: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Database Connection ──────────────────────────────────────────────────────
# Direct Postgres URI — Found in: Supabase Dashboard → Project Settings → Database → Connection String (URI mode)
# Use the "Session" connection string (port 5432) for psycopg2
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# ─── App Secret ───────────────────────────────────────────────────────────────
# Any random long secret string — used for signing / security purposes
APP_SECRET_KEY=replace-with-a-long-random-secret-string
